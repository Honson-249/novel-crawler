# 测试环境配置
# 用于 Linux 测试服部署 (数据库和 Redis 使用 localhost)

# ==================== 应用配置 ====================
APP_ENV=test

# ==================== MySQL 配置 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_test_password_here
MYSQL_DATABASE=fanqie_test
MYSQL_CHARSET=utf8mb4

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== 爬虫配置 ====================
SPIDER_TIMEOUT=30
SPIDER_RETRY_TIMES=3
SPIDER_DELAY_MIN=1
SPIDER_DELAY_MAX=3
SPIDER_HEADLESS=true

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_JSON_FORMAT=false

# ==================== 告警配置 ====================
ALERT_ENABLED=false
ALERT_FEISHU_WEBHOOK=
ALERT_DINGTALK_WEBHOOK=
ALERT_WECHAT_WEBHOOK=
ALERT_FAILURE_RATE_THRESHOLD=0.1
